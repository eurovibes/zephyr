/dts-v1/;
 #include <st/f1/stm32f103Xb.dtsi>
 #include <st/f1/stm32f103r(8-b)tx-pinctrl.dtsi>

 / {
	aliases {
		led0 = &user_led_0;
		led1 = &user_led_1;
                watchdog0 = &iwdg;
		die-temp0 = &die_temp;
        };

        model = "Eurovibes DZLicht NG board";
        compatible = "eurovibes,dzlicht-ng";

        chosen {
                zephyr,console = &usart1;
		zephyr,log-uart = &usart1;
                zephyr,shell-uart = &usart1;
                zephyr,sram = &sram0;
                zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
        };

	leds: leds {
                compatible = "gpio-leds";

                user_led_0: led_0 {
                        gpios = <&gpioa 1 GPIO_ACTIVE_LOW>;
                        label = "User LD0";
                };

		user_led_1: led_1 {
                        gpios = <&gpioa 15 GPIO_ACTIVE_LOW>;
                        label = "User LD1";
                };
        };
};

&clk_hse {
        clock-frequency = <DT_FREQ_M(8)>;
        status = "okay";
};

&clk_lsi {
        status = "okay";
};

&die_temp {
        status = "okay";
};

&flash0 {
        partitions {
                #address-cells = <1>;
                #size-cells = <1>;
                ranges;

                boot_partition: partition@0 {
                        compatible = "zephyr,mapped-partition";
                        label = "mcuboot";
                        reg = <0x00000000 DT_SIZE_K(34)>;
                };

                slot0_partition: partition@8800 {
                        compatible = "zephyr,mapped-partition";
                        label = "image-0";
                        reg = <0x00008800 DT_SIZE_K(45)>;
                };

		slot1_partition: partition@13c00 {
                        compatible = "zephyr,mapped-partition";
                        label = "image-1";
                        reg = <0x00013c00 DT_SIZE_K(46)>;
                };

                storage_partition: partition@1f400 {
                        compatible = "zephyr,mapped-partition";
                        label = "storage";
                        reg = <0x0001f400 DT_SIZE_K(3)>;
                };
        };
};

&iwdg {
        status = "okay";
};

&pll {
        mul = <9>;
        clocks = <&clk_hse>;
        status = "okay";
};

&rcc {
        clocks = <&pll>;
        clock-frequency = <DT_FREQ_M(72)>;
        ahb-prescaler = <1>;
        apb1-prescaler = <2>;
        apb2-prescaler = <1>;
        /* usbpre not set: USB clock = 72 / 1.5: 48MHz */
};

&rtc {
        clocks = <&rcc STM32_CLOCK(APB1, 28)>,
                 <&rcc STM32_SRC_LSI RTC_SEL(2)>;
        status = "okay";
};

&spi1 {
        pinctrl-0 = <&spi1_sck_master_pa5 &spi1_miso_master_pa6 &spi1_mosi_master_pa7>;
        pinctrl-names = "default";
        cs-gpios = <&gpiob 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        status = "okay";
};

&spi2 {
        pinctrl-0 = <&spi2_sck_master_pb13 &spi2_miso_master_pb14 &spi2_mosi_master_pb15>;
        pinctrl-names = "default";
        status = "okay";
};

&timers1 {
        st,prescaler = <10000>;
        status = "okay";

        pwm1: pwm {
                status = "okay";
                pinctrl-0 = <&tim1_ch1_pwm_out_pa8>;
                pinctrl-names = "default";
        };
};

&timers2 {
        st,prescaler = <255>;
        status = "okay";

        pwm2: pwm {
                status = "okay";
                pinctrl-0 = <&tim2_ch1_pwm_out_pa0>;
                pinctrl-names = "default";
        };
};

&usart1 {
        pinctrl-0 = <&usart1_tx_remap1_pb6 &usart1_rx_remap1_pb7>;
        pinctrl-names = "default";
        current-speed = <115200>;
        status = "okay";
};

&usart2 {
        pinctrl-0 = <&usart2_tx_pa2 &usart2_rx_pa3>;
        pinctrl-names = "default";
        current-speed = <115200>;
        status = "okay";
};
